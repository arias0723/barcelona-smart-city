{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoDBWeatherWrite",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:GetItem",
        "dynamodb:Query"
      ],
      "Resource": [
        "arn:aws:dynamodb:eu-west-1:*:table/WeatherData",
        "arn:aws:dynamodb:eu-west-1:*:table/WeatherData/index/*"
      ]
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:eu-west-1:*:log-group:/aws/lambda/smart-city-*"
    }
  ]
}
